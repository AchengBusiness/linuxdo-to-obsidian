{
  "manifest_version": 3,
  "name": "Discourse Saver",
  "version": "4.0.2",
  "description": "一键保存Discourse论坛帖子+评论到Obsidian、飞书多维表格或Notion（支持LinuxDo及所有Discourse论坛）",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://open.feishu.cn/*",
    "https://open.larksuite.com/*",
    "https://api.notion.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detector.js"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
